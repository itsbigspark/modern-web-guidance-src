# Copy .env.example to .env and customize for your machine.
#  Or don't. The defaults in harness/config.js will work for most MacOS setups.

# Jetski Configuration
# Path to your local Jetski directory (used for artifact backup/restore)
JETSKI_DIR=/Users/rviscomi/.gemini/jetski

# Path to the Jetski executable
JETSKI_BIN=/Applications/Jetski.app/Contents/Resources/app/bin/jetski

# Port for Jetski remote debugging
JETSKI_DEBUG_PORT=9226
