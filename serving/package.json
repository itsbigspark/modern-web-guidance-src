{
  "name": "modern-web-mcp",
  "version": "1.0.0",
  "description": "An MCP server for modern web development",
  "type": "module",
  "main": "mcp-server/index.ts",
  "exports": {
    ".": "./mcp-server/index.ts",
    "./lib": "./mcp-server/lib.ts"
  },
  "files": [
    "mcp-server",
    "build",
    ".mcp-data",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsx scripts/build-guides.ts",
    "start": "tsx mcp-server/index.ts",
    "dev": "tsx scripts/build-guides.ts && tsx --watch mcp-server/index.ts",
    "test": "tsx scripts/build-guides.ts && vitest run mcp-server/",
    "typecheck": "npm run build && tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "apache-arrow": "18.1.0",
    "marked": "^17.0.3",
    "web-features": "^3.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "gray-matter": "^4.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}