{
  "name": "modern-web-mcp",
  "version": "1.0.0",
  "description": "An MCP server for modern web development",
  "type": "module",
  "main": "mcp-server/index.ts",
  "exports": {
    ".": "./mcp-server/index.ts",
    "./lib": "./mcp-server/lib.ts"
  },
  "files": [
    "build",
    ".mcp-data",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "node scripts/build-guides.ts",
    "start": "node mcp-server/index.ts",
    "dev": "node scripts/build-guides.ts && node --watch mcp-server/index.ts",
    "test": "node scripts/build-guides.ts && vitest run mcp-server/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.23.0",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "apache-arrow": "18.1.0",
    "marked": "^17.0.1",
    "web-features": "^3.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}