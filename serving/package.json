{
  "name": "modern-web-mcp",
  "version": "1.0.0",
  "description": "An MCP server for modern web development",
  "type": "module",
  "main": "mcp-server/index.ts",
  "exports": {
    ".": "./mcp-server/index.ts",
    "./lib": "./mcp-server/lib.ts"
  },
  "files": [
    "mcp-server",
    "build",
    ".modern-web-data",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "baselinestatus": "node cli/baseline-status.ts",
    "prepublishOnly": "npm run build",
    "build": "node scripts/build-guides.ts",
    "build:megaskill": "node scripts/build-megaskill.ts",
    "build-dist": "node --experimental-strip-types */build-dist.ts",
    "publish-skills": "node --experimental-strip-types skills-cli/publish-skills.ts",
    "start": "node mcp-server/index.ts",
    "dev": "node scripts/build-guides.ts && node --watch mcp-server/index.ts",
    "test": "node scripts/build-guides.ts && vitest run && node --test skills-cli/test-dist.ts",
    "typecheck": "npm run build && tsc --noEmit",
    "benchmark:rag": "node --experimental-strip-types benchmarks/rag/eval-rag-suite.ts",
    "plot:serve": "npx serve benchmarks/data"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.26.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "apache-arrow": "21.1.0",
    "marked": "^17.0.4",
    "web-features": "^3.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/gh-pages": "^6.1.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "gh-pages": "^6.3.0",
    "gpt4all": "^4.0.0",
    "gray-matter": "^4.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}