{
  "name": "guidance",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "pnpm -r test",
    "lint": "oxlint --ignore-path .oxlintignore",
    "typecheck": "pnpm -r typecheck",
    "preflight": "pnpm typecheck && pnpm lint && pnpm test",
    "suite": "pnpm --filter harness suite",
    "qsmoke": "pnpm --filter harness qsmoke",
    "task": "pnpm --filter harness task",
    "run-agent": "node harness/run_suite.ts --with-template",
    "report": "pnpm --filter harness report",
    "dashboard": "pnpm --filter eval-view start",
    "build:mcp": "pnpm --filter modern-web-mcp build",
    "test:mcp": "pnpm --filter modern-web-mcp test",
    "setup:playwright": "pnpm --filter eval-view exec playwright install",
    "generate-negative": "node --env-file=.env guides/negative-gen.ts",
    "generate-grader": "node --env-file=.env guides/grader-gen.ts",
    "grade": "node --experimental-strip-types guides/run-grader.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "packageExtensions": {
      "@google/gemini-cli": {
        "dependencies": {
          "semver": "*"
        }
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/glob": "^9.0.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "glob": "^10.5.0"
  }
}
