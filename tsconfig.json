{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true
  },

  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/grade-report",
    "**/test-app-results/**",
    "harness/results/",
    "**/eval-view",
    "**/eval-view/**/*",
    "harness/base_apps/devtools-times/"
  ]
}
