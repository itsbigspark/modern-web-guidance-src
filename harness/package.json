{
  "name": "harness",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "node --test */*.test.ts",
    "report": "node evaluate.ts",
    "suite": "node run_suite.ts",
    "qsmoke": "node quick-smoke.ts",
    "task": "node run_suite.ts",
    "upload": "node --experimental-strip-types upload_suite.ts",
    "typecheck": "tsc --noEmit",
    "full-run": "npm run suite && npm run report"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.75",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@google-cloud/storage": "^7.19.0",
    "@google/gemini-cli": "^0.33.1",
    "cheerio": "^1.2.0",
    "colors": "^1.4.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "puppeteer-core": "^24.39.1"
  }
}
