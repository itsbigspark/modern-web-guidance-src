{
  "name": "eval-view",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node generate-mapping.js && node server.js",
    "test": "node --test --test-reporter ${TEST_REPORTER:-dot} **/*.test.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc",
    "deploy-pages": "node generate-mapping.js && gh-pages --nojekyll --add --dist ."
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.0",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "playwright": "^1.58.2",
    "serving": "workspace:*",
    "typescript": "^5.9.3"
  }
}